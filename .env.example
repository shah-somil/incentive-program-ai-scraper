# Required for LLM parsing of unstructured pages / PDFs
OPENAI_API_KEY=

# Optional - if you sign up for a free key at https://docs.rewiringamerica.org/signin
# the rewiring_america scraper will use the API directly; otherwise it falls
# back to scraping public calculator pages.
REWIRING_AMERICA_KEY=

# Optional - DSIRE bulk/API key. The dsire_florida scraper works without a key
# by scraping the public website.
DSIRE_KEY=

# Optional - override the OpenAI model
OPENAI_MODEL=gpt-4o-mini
